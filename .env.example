# Dev config. Phase 6 moves secrets to the keyring abstraction; env vars are dev-only.
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://assistant:assistant@localhost:5433/assistant
# non-superuser role so row-level security on the facts table actually enforces
MEMORY_DATABASE_URL=postgresql://assistant_app:assistant_app@localhost:5433/assistant
JWT_PRIVATE_KEY_PATH=keys/broker_private.pem
JWT_PUBLIC_KEY_PATH=keys/broker_public.pem
JWT_TTL_SECONDS=30
JWT_LOW_TIER_TTL_SECONDS=900
USER_ID=user
# tool server data dirs (wrapper passes these through to the MCP subprocess)
NOTES_DIR=data/notes
FILES_ROOT=data/sandbox
# memory: persona folder (dev "vault"), embedding backend (local | hashing)
PERSONA_DIR=data/persona
EMBEDDING_BACKEND=local
RECALL_K=5
RECALL_MIN_SIMILARITY=0.25
